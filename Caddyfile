# YouBox Caddyfile
# 
# Используется с docker-compose (сервис caddy).
# Замените youbox.example.com на ваш домен.
#
# Для работы Let's Encrypt порты 80 и 443 должны быть открыты.
#
# Если используете Cloudflare, настройте DNS-запись типа A на IP сервера
# и используйте tls с DNS-челленджем:
#   tls {
#     dns cloudflare {env.CLOUDFLARE_API_TOKEN}
#   }

# youbox.example.com {
#   # Базовая аутентификация на уровне reverse proxy (опционально)
#   # basicauth {
#   #   admin $2a$14$hash...
#   # }
#
#   reverse_proxy youbox:3000 {
#     # Проброс реального IP клиента
#     header_up X-Forwarded-For {remote_host}
#     header_up X-Forwarded-Proto {scheme}
#     header_up X-Real-IP {remote_host}
#   }
#
#   # Ограничение размера тела запроса (для больших URL)
#   request_body max_size 10MB
#
#   # Логирование
#   log {
#     output file /data/access.log
#     format json
#   }
#
#   # Безопасность
#   header / {
#     X-Content-Type-Options "nosniff"
#     X-Frame-Options "DENY"
#     X-XSS-Protection "1; mode=block"
#     Referrer-Policy "no-referrer"
#     Permissions-Policy "camera=(), microphone=(), geolocation=()"
#   }
# }

# ============================================================
# Альтернатива: dev-режим с самоподписанным сертификатом
# ============================================================
# :443 {
#   tls internal
#   reverse_proxy youbox:3000
# }
