# ============================================================
# YouBox — конфигурация для production (Docker Compose)
# ============================================================
# Скопируйте в .env и заполните:
#   cp .env.example .env && nano .env

# ═══════════════════════════════════════════════════════════
# ⚠️  .env НИКОГДА не должен попасть в git!
# ═══════════════════════════════════════════════════════════
# Этот файл добавлен в .gitignore.
# Перед коммитом проверьте: git status | grep .env

# === Обязательные ===

# SHA-256 хеш от PIN-кода (рекомендуется)
# Сгенерировать: echo -n "твойпин" | shasum -a 256 | cut -d' ' -f1
APP_PIN_HASH=8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92

# AUTH_PIN=123456  # Альтернатива — plaintext PIN (НЕ РЕКОМЕНДУЕТСЯ)

# === Директория данных (внутри контейнера) ===
DATA_DIR=/data

# === Сессии ===
SESSION_TTL=86400              # Время жизни сессии (секунды, 24ч)

# === Файлы ===
FILE_TTL=7200                  # Время жизни готового файла (секунды, 2ч)

# === Безопасность ===
LOGIN_MAX_ATTEMPTS=5           # Максимум неудачных попыток входа
LOGIN_LOCKOUT_DURATION=300     # Блокировка после превышения (секунды, 5мин)

# === yt-dlp ===
# Путь к cookies.txt на хосте (см. docs/COOKIES.md)
# Рекомендуется: /opt/youbox-secrets/youtube.cookies.txt
YT_COOKIES_FILE=
PLAYLIST_MAX_ITEMS=10          # Максимум элементов плейлиста

# === Сервер ===
PORT=3000                      # Порт внутри контейнера (не менять)

# === Логирование ===
LOG_LEVEL=info                 # debug | info | warn | error
